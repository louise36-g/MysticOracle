# ===========================================
# CelestiArcana Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Render PostgreSQL)
# Get this from Render Dashboard → Your Database → Connections
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Clerk Authentication
# Get these from Clerk Dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Payments
# Get these from Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# PayPal Payments
# Get these from PayPal Developer Dashboard
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
PAYPAL_MODE=sandbox  # 'sandbox' or 'live'

# Brevo Email
# Get this from Brevo → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxx

# OpenRouter AI (existing)
OPENROUTER_API_KEY=sk-or-xxxxx

# Sentry Error Tracking (Production only)
# Get this from Sentry → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Cloudinary Media Storage
# Get these from Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx
CLOUDINARY_BASE_FOLDER=celestiarcana
STORAGE_PROVIDER=cloudinary  # 'cloudinary' or 'local'

# Cloudflare Cache Purge (optional — no-op if absent)
# Zone ID: Cloudflare dashboard → your domain → overview (right sidebar)
# API Token: Cloudflare → My Profile → API Tokens → Create Token → Cache Purge template
CLOUDFLARE_ZONE_ID=xxxxx
CLOUDFLARE_API_TOKEN=xxxxx

# Coolify Deploy Trigger (optional — admin "Deploy now" button)
# URL: your Coolify dashboard base URL
# App UUID: Coolify → Front-end app → browser URL, segment after /application/
# API Token: Coolify → Keys & Tokens → Create Token (needs deploy permission)
COOLIFY_DEPLOY_HOST=http://46.224.16.4:8000
COOLIFY_API_TOKEN=xxxxx
COOLIFY_APP_UUID=xxxxx

# Site Configuration (for SEO & Schema.org)
SITE_NAME=CelestiArcana
SITE_URL=https://celestiarcana.com
SITE_LOGO=https://celestiarcana.com/images/logo.png
DEFAULT_AUTHOR_NAME=CelestiArcana Team
DEFAULT_AUTHOR_URL=https://celestiarcana.com/about
