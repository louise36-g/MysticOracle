:{$PORT} {
	# --- Compression: zstd preferred, then gzip ---
	encode {
		zstd
		gzip
		minimum_length 256
	}

	root * ../app/{$NIXPACKS_SPA_OUTPUT_DIR}

	# --- Security Headers ---
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://clerk.celestiarcana.com https://*.clerk.accounts.dev https://challenges.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://api.celestiarcana.com https://res.cloudinary.com https://img.clerk.com https://clerk.celestiarcana.com https://www.googletagmanager.com; connect-src 'self' https://clerk.celestiarcana.com https://*.clerk.accounts.dev https://*.clerk.dev wss://*.clerk.accounts.dev wss://clerk.celestiarcana.com https://api.celestiarcana.com https://www.google-analytics.com https://region1.google-analytics.com https://*.ingest.de.sentry.io https://static.cloudflareinsights.com https://www.googletagmanager.com; frame-src https://challenges.cloudflare.com https://*.clerk.accounts.dev https://clerk.celestiarcana.com; worker-src 'self' blob:; manifest-src 'self'; report-uri https://api.celestiarcana.com/api/v1/health/csp-report;"
		-Server
	}

	# --- Service Worker: always revalidate ---
	@serviceWorker {
		path /sw.js /assets/workbox-*
	}
	header @serviceWorker {
		Cache-Control "no-cache, must-revalidate"
	}

	# --- Hashed assets: immutable forever, noindex ---
	@hashedAssets {
		path /assets/*.js /assets/*.css
	}
	header @hashedAssets {
		Cache-Control "public, max-age=31536000, immutable"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Self-hosted fonts: 1 year cache, noindex ---
	@fonts {
		path /fonts/*
	}
	header @fonts {
		Cache-Control "public, max-age=31536000, immutable"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Static images: 30 days + stale-while-revalidate, noindex ---
	@images {
		path /background-celestiarcana.*
		path /logos/*
		path /icons/*
		path /favicon.png
		path /apple-touch-icon.png
		path /og-image.jpg
		path /screenshots/*
	}
	header @images {
		Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Metadata files: 1 hour + stale-while-revalidate ---
	@metadata {
		path /manifest.json
		path /robots.txt
		path /sitemap.xml
	}
	header @metadata {
		Cache-Control "public, max-age=3600, stale-while-revalidate=86400"
	}

	# --- SPA fallback + HTML caching ---
	@notStaticFile {
		not path /assets/* /fonts/* /logos/* /icons/* /screenshots/*
		not path /background-celestiarcana.* /favicon.png /apple-touch-icon.png
		not path /og-image.jpg /manifest.json /robots.txt /sitemap.xml
		not path /sw.js /deferred-loader.js
	}
	header @notStaticFile {
		Cache-Control "public, max-age=0, must-revalidate"
		Content-Type "text/html; charset=utf-8"
	}

	try_files {path} {path}/index.html /index.html
	file_server
}
