:{$PORT} {
	# --- Compression: zstd preferred, then gzip ---
	encode {
		zstd
		gzip
		minimum_length 256
	}

	root * ../app/{$NIXPACKS_SPA_OUTPUT_DIR}

	# -----------------------------------------------------------------------
	# REDIRECTS
	# Order matters in Caddy — first match wins.
	# Old-URL and slug-rename rules come BEFORE @trailingSlash so that a URL
	# with a trailing slash on an old path resolves in a single 301 hop rather
	# than two (trailing-slash strip + old-URL rewrite).
	# -----------------------------------------------------------------------

	# Old /tarot-card-meanings/suit-of-X → /tarot/cards/X
	# [^/]+ prevents capturing a trailing slash into the group
	@oldSuitPages path_regexp suitpage ^/tarot-card-meanings/suit-of-([^/]+)/?$
	redir @oldSuitPages /tarot/cards/{re.suitpage.1} 301
	@oldSuitPagesFr path_regexp suitpagefr ^/fr/tarot-card-meanings/suit-of-([^/]+)/?$
	redir @oldSuitPagesFr /fr/tarot/cards/{re.suitpagefr.1} 301
	redir /tarot-card-meanings/major-arcana /tarot/cards/major-arcana 301
	redir /fr/tarot-card-meanings/major-arcana /fr/tarot/cards/major-arcana 301
	redir /major-arcana-guide /tarot/cards/major-arcana 301
	redir /fr/major-arcana-guide /fr/tarot/cards/major-arcana 301
	redir /tarot/pentacles /tarot/cards/pentacles 301
	redir /fr/tarot/pentacles /fr/tarot/cards/pentacles 301

	# Slug renames — old short slugs to current canonical form
	redir /tarot/the-tower /tarot/the-tower-tarot-card-meaning 301
	redir /fr/tarot/the-tower /fr/tarot/the-tower-tarot-card-meaning 301
	redir /tarot/5-of-cups-meaning /tarot/5-of-cups-tarot-card-meaning 301
	redir /fr/tarot/5-of-cups-meaning /fr/tarot/5-of-cups-tarot-card-meaning 301
	redir /tarot/the-hermit-meaning /tarot/the-hermit-tarot-card-meaning 301
	redir /fr/tarot/the-hermit-meaning /fr/tarot/the-hermit-tarot-card-meaning 301

	# Blog article slug renames
	redir /blog/major-arcana-tarot-guide /blog/major-arcana-the-fools-journey 301
	redir /fr/blog/major-arcana-tarot-guide /fr/blog/major-arcana-the-fools-journey 301

	# Bad-slug articles: slugs that contained '/' split into nested paths.
	# Must come BEFORE @legacyTarot so the generic /tarot/articles/(.+) rule
	# doesn't capture them first and redirect to another invalid URL.
	redir /tarot/articles/card-tarot-card-meaning/page-of-swords /tarot/page-of-swords-tarot-card-meaning 301
	redir /tarot/articles/card-tarot-card-meaning/four-of-wands /tarot/four-of-wands-tarot-card-meaning 301
	redir /tarot/articles/card-tarot-card-meaning/ten-of-wands /tarot/ten-of-wands-tarot-card-meaning 301
	redir /fr/tarot/articles/card-tarot-card-meaning/page-of-swords /fr/tarot/page-of-swords-tarot-card-meaning 301
	redir /fr/tarot/articles/card-tarot-card-meaning/four-of-wands /fr/tarot/four-of-wands-tarot-card-meaning 301
	redir /fr/tarot/articles/card-tarot-card-meaning/ten-of-wands /fr/tarot/ten-of-wands-tarot-card-meaning 301
	# Without /articles/ prefix (in case the intermediate URL was crawled)
	redir /tarot/card-tarot-card-meaning/page-of-swords /tarot/page-of-swords-tarot-card-meaning 301
	redir /tarot/card-tarot-card-meaning/four-of-wands /tarot/four-of-wands-tarot-card-meaning 301
	redir /tarot/card-tarot-card-meaning/ten-of-wands /tarot/ten-of-wands-tarot-card-meaning 301
	# Bad slug root URLs (the nested-path articles above had a parent URL that Googlebot crawled)
	redir /tarot/card-tarot-card-meaning /tarot/cards 301
	redir /fr/tarot/card-tarot-card-meaning /fr/tarot/cards 301
	# Slugs where "-tarot-card-meaning" was appended to a non-article slug
	redir /tarot/card-meaning-tarot-card-meaning /tarot/cards 301
	redir /fr/tarot/card-meaning-tarot-card-meaning /fr/tarot/cards 301
	# /tarot/cards/X-tarot-card-meanings variant → canonical /tarot/cards/X
	redir /tarot/cards/major-arcana-tarot-card-meanings /tarot/cards/major-arcana 301
	redir /fr/tarot/cards/major-arcana-tarot-card-meanings /fr/tarot/cards/major-arcana 301
	# high-priestess: canonical IS the-high-priestess (previous redirect was backwards)
	redir /tarot/high-priestess-tarot-card-meaning /tarot/the-high-priestess-tarot-card-meaning 301
	redir /fr/tarot/high-priestess-tarot-card-meaning /fr/tarot/the-high-priestess-tarot-card-meaning 301
	# wheel-of-fortune: DB slug has "the-" prefix; card name in constants does not
	redir /tarot/wheel-of-fortune-tarot-card-meaning /tarot/the-wheel-of-fortune-tarot-card-meaning 301
	redir /fr/tarot/wheel-of-fortune-tarot-card-meaning /fr/tarot/the-wheel-of-fortune-tarot-card-meaning 301
	# Other major arcana missing "the-" prefix in generated links
	redir /tarot/fool-tarot-card-meaning /tarot/the-fool-tarot-card-meaning 301
	redir /fr/tarot/fool-tarot-card-meaning /fr/tarot/the-fool-tarot-card-meaning 301
	redir /tarot/devil-tarot-card-meaning /tarot/the-devil-tarot-card-meaning 301
	redir /fr/tarot/devil-tarot-card-meaning /fr/tarot/the-devil-tarot-card-meaning 301
	redir /tarot/hanged-man-tarot-card-meaning /tarot/the-hanged-man-tarot-card-meaning 301
	redir /fr/tarot/hanged-man-tarot-card-meaning /fr/tarot/the-hanged-man-tarot-card-meaning 301
	redir /tarot/moon-tarot-card-meaning /tarot/the-moon-tarot-card-meaning 301
	redir /fr/tarot/moon-tarot-card-meaning /fr/tarot/the-moon-tarot-card-meaning 301
	redir /tarot/star-tarot-card-meaning /tarot/the-star-tarot-card-meaning 301
	redir /fr/tarot/star-tarot-card-meaning /fr/tarot/the-star-tarot-card-meaning 301
	redir /tarot/sun-tarot-card-meaning /tarot/the-sun-tarot-card-meaning 301
	redir /fr/tarot/sun-tarot-card-meaning /fr/tarot/the-sun-tarot-card-meaning 301
	redir /tarot/tower-tarot-card-meaning /tarot/the-tower-tarot-card-meaning 301
	redir /fr/tarot/tower-tarot-card-meaning /fr/tarot/the-tower-tarot-card-meaning 301
	# Minor arcana: word-form slugs → numeric slugs (cups articles use word form)
	redir /tarot/two-of-cups-tarot-card-meaning /tarot/2-of-cups-tarot-card-meaning 301
	redir /tarot/three-of-cups-tarot-card-meaning /tarot/3-of-cups-tarot-card-meaning 301
	redir /tarot/four-of-cups-tarot-card-meaning /tarot/4-of-cups-tarot-card-meaning 301
	redir /tarot/five-of-cups-tarot-card-meaning /tarot/5-of-cups-tarot-card-meaning 301
	redir /tarot/six-of-cups-tarot-card-meaning /tarot/6-of-cups-tarot-card-meaning 301
	redir /tarot/seven-of-cups-tarot-card-meaning /tarot/7-of-cups-tarot-card-meaning 301
	redir /tarot/eight-of-cups-tarot-card-meaning /tarot/8-of-cups-tarot-card-meaning 301
	redir /tarot/nine-of-cups-tarot-card-meaning /tarot/9-of-cups-tarot-card-meaning 301
	redir /tarot/ten-of-cups-tarot-card-meaning /tarot/10-of-cups-tarot-card-meaning 301
	# Catch-all: tarot articles incorrectly linked with /blog/ prefix
	@blogAsTarot path_regexp blog2tarot ^/blog/([a-z0-9-]+-tarot-card-meanings?)$
	redir @blogAsTarot /tarot/{re.blog2tarot.1} 301
	@blogAsTarotFr path_regexp blog2tarotfr ^/fr/blog/([a-z0-9-]+-tarot-card-meanings?)$
	redir @blogAsTarotFr /fr/tarot/{re.blog2tarotfr.1} 301
	# Blog posts with /tarot/ prefix (complete guide articles link to blog sub-articles wrong)
	redir /tarot/major-arcana-deep-dives /blog/major-arcana-deep-dives 301
	redir /tarot/cups-numerology-guide /blog/cups-numerology-guide 301
	redir /tarot/swords-numerology-guide /blog/swords-numerology-guide 301
	redir /tarot/tarot-numerology-complete-guide /blog/tarot-numerology-complete-guide 301
	redir /tarot/the-chariot-as-a-person /blog/the-chariot-as-a-person 301
	redir /tarot/the-chariot-as-feelings /blog/the-chariot-as-feelings 301
	redir /tarot/the-chariot-breakup /blog/the-chariot-breakup 301
	redir /tarot/the-chariot-career-advice /blog/the-chariot-career-advice 301
	redir /tarot/the-chariot-current-situation /blog/the-chariot-current-situation 301
	redir /tarot/the-chariot-how-someone-sees-you /blog/the-chariot-how-someone-sees-you 301
	redir /tarot/the-chariot-love-advice /blog/the-chariot-love-advice 301
	redir /tarot/the-chariot-love-outcome /blog/the-chariot-love-outcome 301
	redir /tarot/the-chariot-obstacle-challenge /blog/the-chariot-obstacle-challenge 301
	redir /tarot/the-chariot-reconciliation /blog/the-chariot-reconciliation 301
	redir /tarot/the-chariot-spirituality /blog/the-chariot-spirituality 301
	redir /tarot/the-chariot-yes-or-no /blog/the-chariot-yes-or-no 301
	redir /tarot/the-moon-breakup /blog/the-moon-breakup 301
	redir /tarot/the-moon-love-advice /blog/the-moon-love-advice 301
	redir /tarot/the-moon-obstacle-challenge /blog/the-moon-obstacle-challenge 301
	redir /tarot/the-moon-yes-or-no /blog/the-moon-yes-or-no 301
	redir /tarot/the-star-as-a-person /blog/the-star-as-a-person 301
	redir /tarot/the-star-as-feelings /blog/the-star-as-feelings 301
	redir /tarot/the-star-breakup /blog/the-star-breakup 301
	redir /tarot/the-star-career-advice /blog/the-star-career-advice 301
	redir /tarot/the-star-current-situation /blog/the-star-current-situation 301
	redir /tarot/the-star-how-someone-sees-you /blog/the-star-how-someone-sees-you 301
	redir /tarot/the-star-love-advice /blog/the-star-love-advice 301
	redir /tarot/the-star-love-outcome /blog/the-star-love-outcome 301
	redir /tarot/the-star-obstacle-challenge /blog/the-star-obstacle-challenge 301
	redir /tarot/the-star-reconciliation /blog/the-star-reconciliation 301
	redir /tarot/the-star-spirituality /blog/the-star-spirituality 301
	redir /tarot/the-star-yes-or-no /blog/the-star-yes-or-no 301
	redir /tarot/the-empress-current-situation /blog/the-empress-current-situation 301
	redir /tarot/the-world-love-advice /blog/the-world-love-advice 301
	redir /tarot/the-world-love-outcome /blog/the-world-love-outcome 301
	redir /tarot/death-breakup /blog/death-breakup 301
	redir /tarot/death-obstacle-challenge /blog/death-obstacle-challenge 301
	# Wheel of Fortune sub-articles: linked with "the-" but blog slugs don't have it
	redir /blog/the-wheel-of-fortune-as-a-person /blog/wheel-of-fortune-as-a-person 301
	redir /blog/the-wheel-of-fortune-as-feelings /blog/wheel-of-fortune-as-feelings 301
	redir /blog/the-wheel-of-fortune-as-yes-or-no /blog/wheel-of-fortune-as-yes-or-no 301
	redir /blog/the-wheel-of-fortune-breakup /blog/wheel-of-fortune-breakup 301
	redir /blog/the-wheel-of-fortune-career-advice /blog/wheel-of-fortune-career-advice 301
	redir /blog/the-wheel-of-fortune-complete-guide /blog/wheel-of-fortune-complete-guide 301
	redir /blog/the-wheel-of-fortune-current-situation /blog/wheel-of-fortune-current-situation 301
	redir /blog/the-wheel-of-fortune-how-someone-sees-you /blog/wheel-of-fortune-how-someone-sees-you 301
	redir /blog/the-wheel-of-fortune-love-advice /blog/wheel-of-fortune-love-advice 301
	redir /blog/the-wheel-of-fortune-love-outcome /blog/wheel-of-fortune-love-outcome 301
	redir /blog/the-wheel-of-fortune-obstacle-challenge /blog/wheel-of-fortune-obstacle-challenge 301
	redir /blog/the-wheel-of-fortune-reconciliation /blog/wheel-of-fortune-reconciliation 301
	redir /blog/the-wheel-of-fortune-spirituality /blog/wheel-of-fortune-spirituality 301
	# Blog articles with "the-" prefix that don't match published slugs
	redir /blog/the-strength-complete-guide /blog/strength-complete-guide 301
	redir /blog/the-justice-complete-guide /blog/justice-complete-guide 301
	redir /blog/the-temperance-complete-guide /blog/temperance-complete-guide 301
	redir /blog/the-major-arcana-tarot-guide /blog/major-arcana-the-fools-journey 301
	redir /tarot/major-arcana-deep-dives /blog/major-arcana-deep-dives 301
	# Typo: "emporer" instead of "emperor" in content
	redir /blog/the-emporer-breakup /blog/the-emperor-breakup 301
	redir /blog/the-emporer-current-situation /blog/the-emperor-current-situation 301
	redir /blog/the-emporer-how-someone-sees-you /blog/the-emperor-how-someone-sees-you 301
	redir /blog/the-emporer-love-advice /blog/the-emperor-love-advice 301
	redir /blog/the-emporer-love-outcome /blog/the-emperor-love-outcome 301
	redir /blog/the-emporer-obstacle-challenge /blog/the-emperor-obstacle-challenge 301
	redir /tarot/the-emporer-as-feelings /blog/the-emperor-as-feelings 301
	redir /tarot/the-emporer-current-situation /blog/the-emperor-current-situation 301
	# Typo: extra "c" prefix on hierophant and magician
	redir /blog/cthe-hierophant-current-situation /blog/the-hierophant-current-situation 301
	redir /blog/cthe-hierophant-obstacle-challenge /blog/the-hierophant-obstacle-challenge 301
	redir /blog/cthe-magician-current-situation /blog/the-magician-current-situation 301
	redir /blog/cthe-magician-obstacle-challenge /blog/the-magician-obstacle-challenge 301
	# FR: French card names used as slugs instead of English slugs
	redir /tarot/la-force-tarot-card-meaning /tarot/strength-tarot-card-meaning 301
	redir /fr/tarot/la-force-tarot-card-meaning /fr/tarot/strength-tarot-card-meaning 301
	redir /tarot/la-papesse-tarot-card-meaning /tarot/the-high-priestess-tarot-card-meaning 301
	redir /fr/tarot/la-papesse-tarot-card-meaning /fr/tarot/the-high-priestess-tarot-card-meaning 301
	redir /tarot/la-roue-de-fortune-tarot-card-meaning /tarot/the-wheel-of-fortune-tarot-card-meaning 301
	redir /fr/tarot/la-roue-de-fortune-tarot-card-meaning /fr/tarot/the-wheel-of-fortune-tarot-card-meaning 301

	# --- Strip trailing slashes (prevents duplicate URLs in Google) ---
	@trailingSlash path_regexp trslash ^(.+)/$
	redir @trailingSlash {re.trslash.1} 301

	# --- Consolidate duplicate pages ---
	redir /tarot /tarot/cards 301
	redir /fr/tarot /fr/tarot/cards 301
	@legacyTarot path_regexp slug ^/tarot/articles/(.+)$
	redir @legacyTarot /tarot/{re.slug.1} 301
	@legacyTarotFr path_regexp slugfr ^/fr/tarot/articles/(.+)$
	redir @legacyTarotFr /fr/tarot/{re.slugfr.1} 301

	# /reading → /tarot-card-reading (SEO rename, preserve rankings)
	# Use path_regexp to capture the suffix so {uri} isn't prepended wholesale.
	@oldReading path_regexp oldread ^/reading(/.*)?$
	redir @oldReading /tarot-card-reading{re.oldread.1} 301
	@oldReadingFr path_regexp oldreadfr ^/fr/reading(/.*)?$
	redir @oldReadingFr /fr/tarot-card-reading{re.oldreadfr.1} 301

	# /yes-no → /tarot-yes-no (SEO rename)
	redir /yes-no /tarot-yes-no 301
	redir /fr/yes-no /fr/tarot-yes-no 301

	# /interpret → /tarot-interpret (SEO rename)
	redir /interpret /tarot-interpret 301
	redir /fr/interpret /fr/tarot-interpret 301

	# /blog?category=X → /blog/category/X (clean URL migration)
	@blogCatQuery {
		path /blog
		query category=*
	}
	redir @blogCatQuery /blog/category/{http.request.uri.query.category} 301
	@blogCatQueryFr {
		path /fr/blog
		query category=*
	}
	redir @blogCatQueryFr /fr/blog/category/{http.request.uri.query.category} 301

	# /blog?tag=X → /blog (strip tag query param — tags don't have clean URLs)
	@blogTagQuery {
		path /blog
		query tag=*
	}
	redir @blogTagQuery /blog 301
	@blogTagQueryFr {
		path /fr/blog
		query tag=*
	}
	redir @blogTagQueryFr /fr/blog 301

	# --- Security Headers ---
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-aWlcEuReX+GS/yvW+HVxUrAI34DGEA0HWqnBUNdtq+o=' https://clerk.celestiarcana.com https://*.clerk.accounts.dev https://challenges.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://api.celestiarcana.com https://res.cloudinary.com https://img.clerk.com https://clerk.celestiarcana.com https://www.googletagmanager.com; connect-src 'self' https://clerk.celestiarcana.com https://*.clerk.accounts.dev https://*.clerk.dev wss://*.clerk.accounts.dev wss://clerk.celestiarcana.com https://api.celestiarcana.com https://www.google-analytics.com https://region1.google-analytics.com https://*.ingest.de.sentry.io https://static.cloudflareinsights.com https://www.googletagmanager.com; frame-src https://challenges.cloudflare.com https://*.clerk.accounts.dev https://clerk.celestiarcana.com; worker-src 'self' blob:; manifest-src 'self'; report-uri https://api.celestiarcana.com/api/v1/health/csp-report;"
		-Server
	}

	# --- Service Worker: always revalidate ---
	@serviceWorker {
		path /sw.js /workbox-*.js
	}
	header @serviceWorker {
		Cache-Control "no-cache, must-revalidate"
		CDN-Cache-Control "no-store"
	}

	# --- deferred-loader.js: never CDN-cache — it controls whether React loads
	# immediately or on interaction; caching the old version at the CDN breaks
	# admin pages when the file is updated.
	@deferredLoader {
		path /deferred-loader.js
	}
	header @deferredLoader {
		Cache-Control "no-cache, must-revalidate"
		CDN-Cache-Control "no-store"
	}

	# --- Admin, auth, payment, protected routes: noindex at server level ---
	# Belt-and-suspenders: robots.txt blocks crawlers, but X-Robots-Tag works even
	# if robots.txt is ignored, and fires before React hydration overrides index.html default.
	@noindexRoutes {
		path /admin /admin/* /payment/* /sign-in /sign-up /profile /tarot-interpret /fr/tarot-interpret /tarot-card-reading/* /fr/tarot-card-reading/*
		path /fr/admin /fr/admin/* /fr/payment/* /fr/sign-in /fr/sign-up /fr/profile
	}
	header @noindexRoutes {
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Hashed assets: immutable forever, noindex ---
	@hashedAssets {
		path /assets/*.js /assets/*.css
	}
	header @hashedAssets {
		Cache-Control "public, max-age=31536000, immutable"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Self-hosted fonts: 1 year cache, noindex ---
	@fonts {
		path /fonts/*
	}
	header @fonts {
		Cache-Control "public, max-age=31536000, immutable"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Static images: 30 days + stale-while-revalidate, noindex ---
	@images {
		path /background-celestiarcana.*
		path /logos/*
		path /icons/*
		path /favicon.png
		path /apple-touch-icon.png
		path /og-image.jpg
		path /screenshots/*
	}
	header @images {
		Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
		X-Robots-Tag "noindex, nofollow"
	}

	# --- Metadata files: 1 hour + stale-while-revalidate ---
	@metadata {
		path /manifest.json
		path /robots.txt
		path /sitemap.xml
		path /sitemap-pages.xml
		path /sitemap-cards.xml
		path /sitemap-blog.xml
	}
	header @metadata {
		Cache-Control "public, max-age=3600, stale-while-revalidate=86400"
	}

	# --- SPA fallback + HTML caching ---
	@notStaticFile {
		not path /assets/* /fonts/* /logos/* /icons/* /screenshots/*
		not path /background-celestiarcana.* /favicon.png /apple-touch-icon.png
		not path /og-image.jpg /manifest.json /robots.txt /sitemap.xml
		not path /sw.js /workbox-*.js /deferred-loader.js
	}
	header @notStaticFile {
		Cache-Control "public, max-age=0, must-revalidate"
		CDN-Cache-Control "no-store"
		Content-Type "text/html; charset=utf-8"
	}

	# --- Blog & tarot content pages: allow Cloudflare to cache for 2 min ---
	# Overrides the CDN-Cache-Control: no-store set above for these paths.
	# 2-minute TTL means stale HTML after a deploy is replaced quickly.
	@contentPage {
		path_regexp ^/(fr/)?(blog|tarot)
	}
	header @contentPage {
		CDN-Cache-Control "max-age=120, stale-while-revalidate=30"
	}

	# Static assets: serve directly, NO SPA fallback
	# Prevents Cloudflare from caching index.html as a JS file during deploys
	handle /assets/* {
		file_server
	}
	handle /fonts/* {
		file_server
	}

	# French SPA fallback: /fr/* paths fall back to French shell
	@frPath {
		path /fr /fr/*
	}
	handle @frPath {
		try_files {path}/index.html {path} /fr/index.html
		file_server
	}

	# English SPA fallback: everything else falls back to English shell
	handle {
		try_files {path}/index.html {path} /index.html
		file_server
	}
}
